theme: dark

tokens:
  color:
    bg: "#0a0a1a"
    card1: "#1e3a5f"
    card2: "#3b1e5f"
    card3: "#5f1e3a"
    card4: "#1e5f3a"
    card5: "#5f3a1e"

root:
  width: 800
  height: 600
  fill: $color.bg
  padding: 40
  gap: 24

  - text: "Z-Index & Absolute Positioning Stress Test"
    font: 700 24 Inter
    color: "#e2e8f0"

  - frame: canvas
    flex: 1
    position: relative

    # Layer 1 - Background cards
    - frame:
      position: absolute
      x: 0
      y: 0
      width: 300
      height: 200
      fill: linear-gradient(135deg, #1e3a5f, #2563eb)
      radius: 16
      z-index: 1
      padding: 20
      shadow: 0 8 32 rgba(37,99,235,0.3)
      - text: "Layer 1"
        font: 700 18 Inter
        color: white

    - frame:
      position: absolute
      x: 60
      y: 40
      width: 300
      height: 200
      fill: linear-gradient(135deg, #3b1e5f, #8b5cf6)
      radius: 16
      z-index: 2
      padding: 20
      shadow: 0 8 32 rgba(139,92,246,0.3)
      - text: "Layer 2"
        font: 700 18 Inter
        color: white

    - frame:
      position: absolute
      x: 120
      y: 80
      width: 300
      height: 200
      fill: linear-gradient(135deg, #5f1e3a, #ec4899)
      radius: 16
      z-index: 3
      padding: 20
      shadow: 0 8 32 rgba(236,72,153,0.3)
      - text: "Layer 3"
        font: 700 18 Inter
        color: white

    - frame:
      position: absolute
      x: 180
      y: 120
      width: 300
      height: 200
      fill: linear-gradient(135deg, #1e5f3a, #10b981)
      radius: 16
      z-index: 4
      padding: 20
      shadow: 0 8 32 rgba(16,185,129,0.3)
      - text: "Layer 4"
        font: 700 18 Inter
        color: white

    - frame:
      position: absolute
      x: 240
      y: 160
      width: 300
      height: 200
      fill: linear-gradient(135deg, #5f3a1e, #f59e0b)
      radius: 16
      z-index: 5
      padding: 20
      shadow: 0 8 32 rgba(245,158,11,0.3)
      - text: "Layer 5 (Top)"
        font: 700 18 Inter
        color: white

    # Floating badge on top of everything
    - frame:
      position: absolute
      x: 350
      y: 10
      width: 120
      height: 40
      fill: "#ef4444"
      radius: 20
      z-index: 10
      align: center
      justify: center
      shadow: 0 4 16 rgba(239,68,68,0.4)
      - text: "z:10"
        font: 700 14 Inter
        color: white

    # Circle shape at bottom-right
    - frame:
      position: absolute
      x: 500
      y: 250
      width: 160
      height: 160
      fill: radial-gradient(circle, #06b6d4, #0c4a6e)
      radius: 80
      shape: circle
      z-index: 6
      align: center
      justify: center
      shadow: 0 8 40 rgba(6,182,212,0.4)
      - text: "Circle"
        font: 700 16 Inter
        color: white
